*.node

# Build artifacts
*.o
*.a
*.lib
*.dll
*.dylib
# …but the Go binding ships prebuilt native libs committed via CI.
# See .githooks/pre-commit for the safety net that prevents humans
# from accidentally committing a local dev build here.
!go/lib/**/*.so
!go/lib/**/*.dylib
!go/lib/**/*.dll
!go/lib/**/*.a

