;; pdf_oxide — Clojure bindings: a thin idiomatic wrapper over the
;; `fyi.oxide:pdf-oxide` Java binding (which owns the single JNI native bridge).
;; No JNA / native code — we call the Java classes directly via interop, and the
;; Java NativeLoader resolves the JNI cdylib via the `fyi.oxide.pdf.lib.path`
;; system property (pointed at the freshly built libpdf_oxide_jni below).
{:paths ["src"]
 :deps {fyi.oxide/pdf-oxide {:mvn/version "0.3.69"}}
 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
   ;; The Java NativeLoader falls back to System.loadLibrary("pdf_oxide_jni"),
   ;; which searches java.library.path (relative entries resolve against the CWD,
   ;; i.e. this `clojure/` dir). Override the override-prop with an ABSOLUTE path
   ;; via -Dfyi.oxide.pdf.lib.path=/abs/... if preferred.
   :jvm-opts ["-Djava.library.path=../target/release"]
   :main-opts ["-m" "cognitect.test-runner"]}
  :example
  {:jvm-opts ["-Dfyi.oxide.pdf.lib.path=../target/release/libpdf_oxide_jni.so"]
   :main-opts ["-m" "pdf-oxide.example"]}
  ;; Shared-scenario regression examples (html / words / tables). Each asserts
  ;; and prints its "<NAME> OK" line; CI greps for it and fails on non-zero exit.
  :example-html
  {:jvm-opts ["-Dfyi.oxide.pdf.lib.path=../target/release/libpdf_oxide_jni.so"]
   :main-opts ["-m" "pdf-oxide.example-html"]}
  :example-words
  {:jvm-opts ["-Dfyi.oxide.pdf.lib.path=../target/release/libpdf_oxide_jni.so"]
   :main-opts ["-m" "pdf-oxide.example-words"]}
  :example-tables
  {:jvm-opts ["-Dfyi.oxide.pdf.lib.path=../target/release/libpdf_oxide_jni.so"]
   :main-opts ["-m" "pdf-oxide.example-tables"]}
  ;; Build + deploy to Clojars: `clojure -T:build jar` / `clojure -T:build deploy`
  ;; (deploy reads CLOJARS_USERNAME / CLOJARS_PASSWORD from the environment).
  :build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.5"}
          slipset/deps-deploy {:mvn/version "0.2.2"}}
   :ns-default build}
  ;; Format check: `clojure -M:cljfmt check` (and `clojure -M:cljfmt fix`).
  :cljfmt
  {:deps {dev.weavejester/cljfmt {:mvn/version "0.13.0"}}
   :main-opts ["-m" "cljfmt.main"]}}}
